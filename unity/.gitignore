# ===== Unity Standard Ignore Rules =====
# Source: https://github.com/github/gitignore/blob/main/Unity.gitignore

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# Additional Unity temp folders
.utmp/
Temp/

# Memory captures (large & sensitive)
[Mm]emoryCaptures/

# Recordings
[Rr]ecordings/

# Ignore specific asset store tools plugin (optional)
# [Aa]ssets/AssetStoreTools*

# JetBrains Rider plugin (auto-generated)
[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio / .NET related
.vs/
.gradle/

# Autogenerated solution/project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity meta files for pdb/mdb
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity crash report
sysinfo.txt

# Build outputs
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics
crashlytics-build.properties

# Addressables binary data
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary Android StreamingAssets data
[Aa]ssets/[Ss]treamingAssets/aa.meta
[Aa]ssets/[Ss]treamingAssets/aa/*

# Lighting Data (auto-generated, extremely large)
LightingData.asset
*/LightingData.asset

# Unity resource files that should not be tracked
*.resS